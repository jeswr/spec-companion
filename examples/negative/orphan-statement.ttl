# AUTHORED-BY Claude Fable 5
# EXPECTED FAIL (SHACL): <#EX-2> is a typed spec:Requirement but is NOT linked from the
# specification via spec:requirement — an orphan invisible to consumers traversing the
# spec node.
@base <https://spec.example/spec.statements.ttl> .
@prefix sc:      <https://w3id.org/jeswr/spec-companion#> .
@prefix spec:    <http://www.w3.org/ns/spec#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<> a sc:CompanionDocument ;
    sc:companionOf <https://spec.example/> ;
    sc:specVersion "0123456789abcdef" ;
    dcterms:created "2026-07-06"^^xsd:date ;
    prov:wasAttributedTo <https://jeswr.org/#me> .

<https://spec.example/> a spec:Specification ;
    dcterms:title "Example Protocol"@en ;
    spec:conformance <https://spec.example/#conformance> ;
    spec:consideration <https://spec.example/#security> ;
    spec:requirement <#EX-1> .

<https://spec.example/#security> a spec:SecurityConsiderations .

<#Server> a sc:ConformanceClass ;
    rdfs:label "Example server"@en ;
    sc:definedBy <https://spec.example/#terminology> .

<#EX-1> a spec:Requirement ;
    dcterms:identifier "EX-1" ;
    spec:statement "The server MUST reject unsigned requests." ;
    spec:requirementLevel spec:MUST ;
    spec:requirementSubject <#Server> ;
    sc:testability sc:Enforceable ;
    sc:anchor <https://spec.example/#rejection> ;
    spec:testCase <https://github.com/example/vectors/blob/main/cases/reject-unsigned/case.json> .

# The orphan: valid in every per-statement respect, but never referenced by the spec.
<#EX-2> a spec:Requirement ;
    dcterms:identifier "EX-2" ;
    spec:statement "The server MUST reject expired tokens." ;
    spec:requirementLevel spec:MUST ;
    spec:requirementSubject <#Server> ;
    sc:testability sc:Enforceable ;
    sc:anchor <https://spec.example/#expiry> ;
    spec:testCase <https://github.com/example/vectors/blob/main/cases/reject-expired/case.json> .
